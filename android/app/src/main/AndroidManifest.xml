<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.jar.spider">

    <!-- 🌐 INTERNET -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- 🎤 VOICE -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>

    <!-- 📞 CALL -->
    <uses-permission android:name="android.permission.CALL_PHONE"/>

    <!-- 📇 CONTACTS -->
    <uses-permission android:name="android.permission.READ_CONTACTS"/>

    <!-- 📩 SMS -->
    <uses-permission android:name="android.permission.SEND_SMS"/>

    <!-- 📡 BLUETOOTH (ESP32 / Devices) -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"/>
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"/>

    <!-- ⚠️ Required for Android < 12 -->
    <uses-permission android:name="android.permission.BLUETOOTH"/>
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"/>

    <!-- 📍 (Optional - only if you use location later) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>

    <application
        android:label="Spider Jarvis"
        android:icon="@mipmap/launcher_icon"
        android:usesCleartextTraffic="true">

        <!-- 🔥 MAIN ACTIVITY -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <!-- LAUNCH -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Required by Flutter -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

    </application>

    <!-- 🔍 QUERY INTENTS (REQUIRED FOR ANDROID 11+) -->
    <queries>

        <!-- Browser -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>

        <!-- Dial -->
        <intent>
            <action android:name="android.intent.action.DIAL"/>
        </intent>

        <!-- SMS -->
        <intent>
            <action android:name="android.intent.action.SENDTO"/>
            <data android:scheme="sms"/>
        </intent>

        <!-- WhatsApp -->
        <package android:name="com.whatsapp"/>

        <!-- Apps -->
        <package android:name="com.google.android.youtube"/>
        <package android:name="com.instagram.android"/>
        <package android:name="com.spotify.music"/>
        <package android:name="com.google.android.gm"/>
        <package android:name="org.telegram.messenger"/>
        <package android:name="com.netflix.mediaclient"/>
        <package android:name="com.phonepe.app"/>
        <package android:name="com.google.android.apps.maps"/>

    </queries>

</manifest>
